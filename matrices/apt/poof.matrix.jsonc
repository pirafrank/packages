{
    "include": [
        { "arch": "amd64",   "target": "x86_64-unknown-linux-gnu",      "glibc_max": "2.23" },
        { "arch": "arm64",   "target": "aarch64-unknown-linux-gnu",     "glibc_max": "2.23" },
        { "arch": "armhf",   "target": "armv7-unknown-linux-gnueabihf", "glibc_max": "2.23" },
        { "arch": "i386",    "target": "i686-unknown-linux-gnu",        "glibc_max": "2.23" },
        { "arch": "riscv64", "target": "riscv64gc-unknown-linux-gnu",   "glibc_max": "2.35" }
    ]
}
