{
    "include": [
        { "arch": "amd64",   "target": "x86_64-unknown-linux-gnu",      "rpm_arch": "x86_64",  "glibc_max": "2.23" },
        { "arch": "arm64",   "target": "aarch64-unknown-linux-gnu",     "rpm_arch": "aarch64", "glibc_max": "2.23" },
        { "arch": "armhf",   "target": "armv7-unknown-linux-gnueabihf", "apt_only": true,       "glibc_max": "2.23" },
        { "arch": "i386",    "target": "i686-unknown-linux-gnu",        "apt_only": true,       "glibc_max": "2.23" },
        { "arch": "riscv64", "target": "riscv64gc-unknown-linux-gnu",   "apt_only": true,       "glibc_max": "2.35" }
    ]
}
